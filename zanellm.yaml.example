# =============================================================================
# ZaneLLM Configuration
# =============================================================================
#
# Environment variable interpolation: use ${VAR} or ${VAR:-default}
# All secrets should be passed via environment variables, not hardcoded here.
#
# Config file location (in order of precedence):
#   1. --config flag
#   2. ZANELLM_CONFIG env var
#   3. ./zanellm.yaml
#   4. /etc/zanellm/zanellm.yaml


# =============================================================================
# SERVER
# =============================================================================

server:
  # Proxy port — OpenAI-compatible API (/v1/*)
  # This is the hot path. LLM clients point here.
  proxy:
    port: 8080
    read_timeout: 30s
    write_timeout: 120s      # Must be high for streaming responses
    idle_timeout: 60s

  # Admin port — Admin API (/api/v1/*), UI (/), metrics, health
  # port: 0 means everything runs on the proxy port (default, recommended for simple setups)
  # Set to e.g. 8443 to isolate admin traffic (recommended for production)
  admin:
    port: 0
    tls:
      enabled: false
      cert: /certs/tls.crt
      key:  /certs/tls.key


# =============================================================================
# DATABASE
# =============================================================================

database:
  # driver: sqlite (default) | postgres
  driver: sqlite

  # SQLite: path to the database file
  # Use a persistent volume in Docker/Kubernetes
  dsn: /data/zanellm.db

  # PostgreSQL example:
  # driver: postgres
  # dsn: postgres://zanellm:${DB_PASSWORD}@postgres:5432/zanellm?sslmode=require

  # Connection pool (ignored for SQLite)
  max_open_conns: 25
  max_idle_conns: 5
  conn_max_lifetime: 5m


# =============================================================================
# CACHE
# =============================================================================

cache:
  # How long to keep keys/models in the in-memory cache before refreshing from DB
  # Lower = more responsive to changes, higher = less DB load
  key_ttl:   30s
  model_ttl: 60s
  alias_ttl: 60s


# =============================================================================
# REDIS (optional)
# =============================================================================
# Only needed for multi-instance deployments.
# Enables: distributed rate limiting, instant cache invalidation across instances.
# Without Redis: rate limits and cache are per-instance (fine for single instance).

redis:
  enabled: false
  url: redis://:${REDIS_PASSWORD}@redis:6379/0
  # url: redis://redis:6379/0     # no password

  # Prefix for all ZaneLLM keys in Redis (useful if Redis is shared)
  key_prefix: zanellm:


# =============================================================================
# MODELS
# =============================================================================
# Static model registry. Models defined here are loaded at startup.
# Models can also be managed via the Admin API (stored in DB).
# DB models take precedence over YAML models on name collision.
#
# Supported providers:
#   vllm       — OpenAI-compatible, direct passthrough
#   openai     — OpenAI API, direct passthrough
#   anthropic  — Anthropic API, request/response translation applied
#   azure      — Azure OpenAI, URL mapping applied
#   custom     — Any OpenAI-compatible endpoint, direct passthrough

models:
  # --- Simple single-endpoint model ---
  - name: gpt-oss-120b
    provider: vllm
    type: chat                       # chat (default), image, audio_transcription, tts
    base_url: http://vllm-large:8000/v1
    api_key: ${VLLM_LARGE_KEY}       # Optional, depends on upstream config
    timeout: 60s                     # Per-model upstream timeout (overrides global)
    aliases:
      - large
      - default
    max_context_tokens: 128000
    pricing:
      input_per_1m:  0.50
      output_per_1m: 1.50
    # pii_filter: false              # Explicit override: never anonymize for this model.
    #                                # Default (absent): public destinations anonymize,
    #                                # private/loopback destinations pass through as-is.
    #                                # pii_filter: true  forces anonymization even on private URLs.
    #                                # pii_filter: false disables anonymization even on public URLs.
    #                                # WARNING: pii_filter: false sends prompt content (including any
    #                                # PII) to this upstream IN CLEARTEXT, even for public endpoints.
    #                                # This is a deliberate opt-out for upstreams you trust; only set
    #                                # it when you are sure the destination is acceptable for raw data.

  - name: gpt-oss-20b
    provider: vllm
    base_url: http://vllm-small:8000/v1
    api_key: ${VLLM_SMALL_KEY}
    aliases:
      - small
      - fast
    # fallback: gpt-oss-120b  # Enterprise: retry on this model when gpt-oss-20b is unavailable
    max_context_tokens: 32000
    pricing:
      input_per_1m:  0.10
      output_per_1m: 0.30

  - name: claude-sonnet
    provider: anthropic
    base_url: https://api.anthropic.com
    api_key: ${ANTHROPIC_KEY}
    aliases:
      - smart
    max_context_tokens: 200000
    pricing:
      input_per_1m:  3.00
      output_per_1m: 15.00

  - name: gpt-4o-azure
    provider: azure
    base_url: https://mycompany.openai.azure.com
    api_key: ${AZURE_OPENAI_KEY}
    azure_deployment: gpt-4o
    azure_api_version: "2024-02-01"
    max_context_tokens: 128000

  - name: text-embedding-3-small
    provider: openai
    type: embedding
    base_url: https://api.openai.com/v1
    api_key: ${OPENAI_KEY}
    aliases:
      - embedding
      - embed

  # --- Multi-deployment model with load balancing ---
  - name: gpt-4o
    type: chat
    strategy: round-robin            # round-robin, least-latency, weighted, priority
    max_retries: 2                   # Retry across deployments on failure
    aliases:
      - smart
    max_context_tokens: 128000
    pricing:
      input_per_1m:  2.50
      output_per_1m: 10.00
    deployments:
      - name: azure-east
        provider: azure
        base_url: https://eastus.openai.azure.com
        api_key: ${AZURE_EAST_KEY}
        azure_deployment: gpt-4o
        azure_api_version: "2024-02-01"
        weight: 2                    # For weighted strategy
        priority: 1                  # For priority strategy (lower = higher priority)
        # pii_filter: true           # Per-deployment override (takes precedence over model-level flag)
      - name: azure-west
        provider: azure
        base_url: https://westus.openai.azure.com
        api_key: ${AZURE_WEST_KEY}
        azure_deployment: gpt-4o
        azure_api_version: "2024-02-01"
        weight: 1
        priority: 2


# =============================================================================
# SETTINGS
# =============================================================================

settings:
  # Bootstrap admin key — used ONLY when the database is empty (first startup).
  # After first startup, create a proper user with system_admin role and remove this.
  # Must be at least 32 characters.
  admin_key: ${ZANELLM_ADMIN_KEY}

  # Encryption key for upstream API keys stored in the database.
  # AES-256-GCM. Must be exactly 32 bytes (256 bits), base64-encoded.
  # Generate with: openssl rand -base64 32
  # Changing this key will invalidate all stored upstream API keys.
  encryption_key: ${ZANELLM_ENCRYPTION_KEY}

  # Enterprise license key (leave empty for OSS mode)
  license: ${ZANELLM_LICENSE}

  # Async usage logging
  usage:
    buffer_size:    1000    # Max events in buffer before flush
    flush_interval: 5s      # Flush to DB at least every N seconds
    # If buffer is full, new events are dropped (never blocks the hot path)
    drop_on_full: true

  # Token counting for soft pre-checks
  # Uses tiktoken-go estimation (±3-5% accuracy for non-OpenAI models)
  token_counting:
    enabled: true

  # Soft limit behavior: warn in logs when a key/team/org is approaching their limit
  # Hard limits are always enforced via DB aggregate
  soft_limit_threshold: 0.9   # Warn at 90% of limit

  # MCP Gateway settings
  mcp:
    call_timeout: 30s             # Timeout for proxied MCP tool calls
    allow_private_urls: false     # Block MCP servers on private/loopback IPs
    code_mode:
      enabled: false              # Enable WASM-sandboxed JS execution
      memory_limit_mb: 16         # Memory limit per execution
      timeout: 30s                # Execution timeout
      pool_size: 8                # WASM runtime pool size
      max_tool_calls: 50          # Max tool calls per execution

  # Health checks
  health_check:
    health:
      enabled: true
      interval: 30s
    functional:
      enabled: true
      interval: 5m

  # --- Enterprise Features (require license) ---

  # Model fallback chains: retry a different model when the primary is unavailable.
  # Requires a license with the fallback_chains feature; ignored otherwise.
  # fallback_max_depth: 3
  #   Maximum depth of the model fallback chain.
  #   - 0 (default, if unset): fallback chains disabled globally
  #   - 1-10: enables fallback chains, capped at this depth
  #   Requires Enterprise license.

  # Audit logging
  # audit:
  #   enabled: true
  #   buffer_size: 500
  #   flush_interval: 5s

  # Circuit breaker for upstream providers
  # circuit_breaker:
  #   enabled: true
  #   threshold: 5
  #   timeout: 30s
  #   half_open_max: 1

  # OpenTelemetry tracing
  # otel:
  #   enabled: true
  #   endpoint: "localhost:4317"
  #   insecure: false
  #   sample_rate: 1.0

  # Data retention - periodic deletion of old usage and audit records.
  # Disabled by default (zero duration = keep forever).
  # retention:
  #   usage_events: 90d   # delete usage_events rows older than 90 days
  #   audit_logs: 365d    # delete audit_logs rows older than 1 year
  #   interval: 24h       # how often the cleanup job runs (default: 24h)

  # SSO/OIDC authentication
  # sso:
  #   enabled: true
  #   issuer: "https://accounts.google.com"
  #   client_id: ${ZANELLM_SSO_CLIENT_ID}
  #   client_secret: ${ZANELLM_SSO_CLIENT_SECRET}
  #   redirect_url: "https://zanellm.company.com/api/v1/auth/oidc/callback"
  #   scopes: ["openid", "email", "profile"]
  #   allowed_domains: ["company.com"]
  #   default_role: "member"
  #   auto_provision: true

  # PII anonymization - replace PII in outbound prompts with pseudonyms.
  # Pseudonyms are restored in the response; no PII is ever persisted or logged.
  # Applies only to external providers (openai, anthropic, azure, gemini, vertex).
  # Disabled by default. Only "pseudonymize" is supported as action.
  # pii:
  #   enabled: false
  #   action: pseudonymize
  #   patterns:                     # custom patterns added to the built-in defaults
  #     - type: PASSPORT_NO
  #       regexp: '\b[A-Z]{1,3}[0-9]{6,9}\b'


# =============================================================================
# LOGGING
# =============================================================================

logging:
  level: info                     # debug, info, warn, error
  format: json                    # json or text


# =============================================================================
# MCP SERVERS (optional)
# =============================================================================
# External MCP servers to register at startup.
# Servers can also be managed via the Admin API (stored in DB).
# Global servers require explicit org-level access (closed-by-default).

# mcp_servers:
#   - name: GitHub
#     alias: github
#     url: https://mcp.github.com/sse
#     auth_type: bearer
#     auth_token: ${GITHUB_TOKEN}
